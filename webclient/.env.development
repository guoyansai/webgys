# 环境配置(可以用在index.html中，注意以VITE_开头)
NODE_ENV = "development"
VITE_ENV_TYPE="development"
VITE_OBFUSCATE_ENABLE=0  # 或 1 来关闭混淆
VITE_MAIN_JS="main"
VITE_WEB_PATH = "/"
VITE_API_URL = "/api"
VITE_HTTP_HOST=localhost
VITE_HTTP_PORT=8000
VITE_HTTP_API=http://localhost:9198
VITE_DIST_DIR=../webserver/webclient/