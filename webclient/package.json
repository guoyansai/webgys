{
  "name": "webclient",
  "version": "0.0.1",
  "author": "asai.cc",
  "license": "ISC",
  "description": "WEB client for ASAI & CoControl (Vue3 + Vite)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
